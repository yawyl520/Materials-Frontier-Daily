{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["en", "zh"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "",
    "sender_name": "Materials Frontier Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "materialsproject",
        "repo": "pymatgen",
        "enabled": true,
        "category": "computational-materials"
      },
      {
        "type": "repo_releases",
        "owner": "materialsproject",
        "repo": "mp-api",
        "enabled": true,
        "category": "computational-materials"
      },
      {
        "type": "repo_releases",
        "owner": "deepmodeling",
        "repo": "deepmd-kit",
        "enabled": true,
        "category": "computational-materials"
      },
      {
        "type": "repo_releases",
        "owner": "aiida-core",
        "repo": "aiida-core",
        "enabled": true,
        "category": "computational-materials"
      }
    ],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "arXiv Materials Science",
        "url": "https://rss.arxiv.org/rss/cond-mat.mtrl-sci",
        "enabled": true,
        "category": "preprints"
      },
      {
        "name": "arXiv Soft Condensed Matter",
        "url": "https://rss.arxiv.org/rss/cond-mat.soft",
        "enabled": true,
        "category": "soft-materials"
      },
      {
        "name": "arXiv Mesoscale and Nanoscale Physics",
        "url": "https://rss.arxiv.org/rss/cond-mat.mes-hall",
        "enabled": true,
        "category": "nano-materials"
      },
      {
        "name": "arXiv Strongly Correlated Electrons",
        "url": "https://rss.arxiv.org/rss/cond-mat.str-el",
        "enabled": true,
        "category": "quantum-materials"
      },
      {
        "name": "Nature Materials",
        "url": "https://www.nature.com/nmat/current_issue/rss/",
        "enabled": true,
        "category": "top-journals"
      },
      {
        "name": "Nature Nanotechnology",
        "url": "https://www.nature.com/nnano/current_issue/rss/",
        "enabled": true,
        "category": "nano-materials"
      },
      {
        "name": "Nature Reviews Materials",
        "url": "https://www.nature.com/natrevmats/current_issue/rss/",
        "enabled": true,
        "category": "reviews"
      },
      {
        "name": "Nature Energy",
        "url": "https://www.nature.com/nenergy/current_issue/rss/",
        "enabled": true,
        "category": "energy-materials"
      },
      {
        "name": "npj Computational Materials",
        "url": "https://www.nature.com/npjcompumats/current_issue/rss/",
        "enabled": true,
        "category": "computational-materials"
      },
      {
        "name": "npj 2D Materials and Applications",
        "url": "https://www.nature.com/npj2dmaterials/current_issue/rss/",
        "enabled": true,
        "category": "nano-materials"
      },
      {
        "name": "npj Quantum Materials",
        "url": "https://www.nature.com/npjquantmats/current_issue/rss/",
        "enabled": true,
        "category": "quantum-materials"
      },
      {
        "name": "npj Materials Degradation",
        "url": "https://www.nature.com/npjmatdeg/current_issue/rss/",
        "enabled": true,
        "category": "structural-materials"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 0
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python"],
      "keywords": ["materials", "chemistry", "simulation"],
      "min_stars": 50,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 6.5,
    "time_window_hours": 48,
    "max_items": 16,
    "category_groups": {
      "frontier-papers": {
        "limit": 8,
        "categories": ["preprints", "top-journals", "reviews"]
      },
      "materials-themes": {
        "limit": 6,
        "categories": ["energy-materials", "nano-materials", "quantum-materials", "soft-materials", "structural-materials"]
      },
      "tools": {
        "limit": 3,
        "categories": ["computational-materials"]
      }
    },
    "default_group": "other",
    "default_group_limit": 2
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "text": "#{message_title}\n#{summary}"
    },
    "headers": ""
  }
}
